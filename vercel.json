{
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/refund/:token", "destination": "/refund.html?token=:token" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
