{
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/refund/:token", "destination": "/refund.html?token=:token" },
    { "source": "/partner", "destination": "/partner.html" },
    { "source": "/partner/restaurant", "destination": "/partner-restaurant.html" },
    { "source": "/partner/livreur", "destination": "/partner-livreur.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
